"""drift-[[key]]: [[plugin_name]] drift detection plugin."""

from pathlib import Path
from flask import Blueprint
from .detector import [[class_name]]

__version__ = "[[version]]"

_PKG_DIR = Path(__file__).resolve().parent

blueprint = Blueprint(
    "[[key]]",
    __name__,
    template_folder=str(_PKG_DIR / "web" / "templates"),
    static_folder=str(_PKG_DIR / "web" / "static"),
    static_url_path="/[[key]]-static",
    url_prefix="/drift/[[key]]",
)

from .web.routes import register_routes  # noqa: E402
register_routes(blueprint)


def register(app):
    from framework.plugin.types import PluginInfo

    app.register_blueprint(blueprint)

    return PluginInfo(
        key="[[key]]",
        name="[[plugin_name]]",
        version=__version__,
        description="[[description]]",
        category="[[category]]",
        card_template="[[key]]/card.html",
        page_url="/drift/[[key]]/",
        icon="chart-bar",
        detector_class=[[class_name]],
        params_schema=[[class_name]].DEFAULT_PARAMS,
    )
