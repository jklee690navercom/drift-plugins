[build-system]
requires = ["setuptools>=68.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "drift-[[key]]"
version = "[[version]]"
description = "[[description]]"
requires-python = ">=3.11"
dependencies = [
    "drift-framework>=0.1,<1.0",
]

[project.entry-points."drift_framework.plugins"]
[[key]] = "drift_[[key_underscore]]:register"

[tool.setuptools.packages.find]
include = ["drift_[[key_underscore]]*"]

[tool.setuptools.package-data]
drift_[[key_underscore]] = [
    "web/templates/**/*",
    "web/static/**/*",
    "examples/*.csv",
]
